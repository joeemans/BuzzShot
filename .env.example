# Shared
NODE_ENV=development

# Web
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000/api

# API
API_PORT=4000
API_URL=http://localhost:4000
WEB_URL=http://localhost:3000
DATABASE_URL=postgresql://buzzshot:buzzshot@localhost:5432/buzzshot?schema=public
REDIS_URL=redis://localhost:6379
JWT_ACCESS_SECRET=replace-with-a-long-random-access-secret
JWT_ACCESS_TTL_SECONDS=900
REFRESH_TOKEN_COOKIE_NAME=buzzshot_refresh
REFRESH_TOKEN_TTL_DAYS=30
COOKIE_SECURE=false
TMDB_API_BASE_URL=https://api.themoviedb.org/3
TMDB_IMAGE_BASE_URL=https://image.tmdb.org/t/p
TMDB_READ_ACCESS_TOKEN=replace-with-your-tmdb-api-read-access-token
TMDB_API_KEY=replace-with-your-tmdb-api-key
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4000/api/auth/google/callback
